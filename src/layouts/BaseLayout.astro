---
import "../styles/global.css";
import LanguageSwitcher from "../components/LanguageSwitcher";

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
  /** Current language from URL path (e.g. "zh", "en", "ja") */
  lang?: string;
}

const {
  title,
  description = "我的数字花园 — 记录思考，分享知识。Obsidian 笔记公开站。",
  ogImage = "/og-default.png",
  noIndex = false,
  lang = "zh",
} = Astro.props;

// HTML lang code — use "zh" for Chinese, "en" for English, etc.
const htmlLang = ["zh", "en", "ja", "fr", "es", "pt", "de", "it"].includes(lang) ? lang : "zh";

// Nav links — all prefixed with /{lang}/
const L = `/${lang}`;
---

<!doctype html>
<html lang={htmlLang} data-theme="light" data-page-lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#6366f1" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="My AI Assets" />

    <!-- Preload font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <!-- SEO -->
    <title>{title} — My AI Assets</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={`${title} — My AI Assets`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    {noIndex && <meta name="robots" content="noindex" />}

    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.url.origin).href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/icon-192.png" />

    <!-- Anti-flash theme -->
    <script is:inline>
      (function () {
        const s = localStorage.getItem("theme");
        const d = window.matchMedia("(prefers-color-scheme: dark)").matches;
        if (s === "dark" || (!s && d)) document.documentElement.setAttribute("data-theme", "dark");
      })();
    </script>
  </head>

  <body class="min-h-screen flex flex-col">
    <!-- Nav -->
    <header class="sticky top-0 z-50 border-b transition-all duration-300" style="background: var(--glass-bg); backdrop-filter: blur(var(--glass-blur)); -webkit-backdrop-filter: blur(var(--glass-blur)); border-color: var(--color-border);">
      <nav class="container flex items-center justify-between h-14" role="navigation" aria-label="主导航">
        <!-- Logo -->
        <a href={`${L}/`} class="flex items-center gap-2 no-underline group" aria-label="回到首页">
          <span class="text-xl">🤖</span>
          <span class="text-lg font-extrabold tracking-tight hidden sm:inline" style="color: var(--color-text)">My AI Assets</span>
        </a>

        <!-- Desktop nav -->
        <div class="hidden sm:flex items-center gap-1">
          <a href={`${L}/notes/`} class="nav-link" aria-current={Astro.url.pathname.startsWith("/notes") ? "page" : undefined} data-i="nav.notes">笔记</a>
          <a href={`${L}/timeline/`} class="nav-link" aria-current={Astro.url.pathname === "/timeline" ? "page" : undefined} data-i="nav.timeline">时间线</a>
          <a href={`${L}/subscribe/`} class="nav-link" aria-current={Astro.url.pathname === "/subscribe" ? "page" : undefined} data-i="nav.subscribe">订阅</a>
          <a href={`${L}/publish/`} class="nav-btn-primary" aria-current={Astro.url.pathname === "/publish" ? "page" : undefined} data-i="nav.publish">✍️ 发布</a>
          <a href={`${L}/admin/`} class="nav-link" aria-current={Astro.url.pathname === "/admin" ? "page" : undefined}
             style="font-size: 0.8rem; opacity: 0.7;">🛡️</a>
          <div class="w-px h-6 mx-2" style="background: var(--color-border)"></div>
          <LanguageSwitcher client:load currentLang={lang} />
          <theme-toggle />
        </div>

        <!-- Mobile -->
        <div class="flex sm:hidden items-center gap-2">
          <LanguageSwitcher client:load currentLang={lang} />
          <theme-toggle />
          <button id="mobile-menu-btn" class="flex items-center justify-center rounded-lg" style="min-height:44px; min-width:44px; color: var(--color-text)" aria-label="打开菜单">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
              <line x1="4" y1="6" x2="20" y2="6" /><line x1="4" y1="12" x2="20" y2="12" /><line x1="4" y1="18" x2="20" y2="18" />
            </svg>
          </button>
        </div>
      </nav>
    </header>

    <!-- Mobile drawer overlay -->
    <div id="mobile-drawer-overlay" class="fixed inset-0 z-40 bg-black/50 hidden sm:hidden backdrop-blur-sm" onclick="document.getElementById('mobile-drawer')?.classList.add('translate-x-full');this.classList.add('hidden')"></div>

    <!-- Mobile drawer -->
    <aside id="mobile-drawer" class="fixed top-0 right-0 z-50 h-full w-72 transform translate-x-full transition-transform duration-300 ease-out sm:hidden shadow-xl" style="background: var(--color-surface); border-left: 1px solid var(--color-border)">
      <div class="flex items-center justify-between p-4 border-b" style="border-color: var(--color-border)">
        <span class="font-bold text-lg" style="color: var(--color-text)">📝 导航</span>
        <button class="flex items-center justify-center rounded-lg" style="min-height:44px;min-width:44px;color:var(--color-text)" aria-label="关闭" onclick="document.getElementById('mobile-drawer')?.classList.add('translate-x-full');document.getElementById('mobile-drawer-overlay')?.classList.add('hidden')">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <nav class="p-4 space-y-1">
        <a href={`${L}/`} class="drawer-link"><span data-i="nav.home">🏠 首页</span></a>
        <a href={`${L}/notes/`} class="drawer-link"><span data-i="nav.notes">📂 笔记</span></a>
        <a href={`${L}/timeline/`} class="drawer-link"><span data-i="nav.timeline">⏰ 时间线</span></a>
        <a href={`${L}/publish/`} class="drawer-link"><span data-i="nav.publish">✍️ 发布文章</span></a>
        <a href={`${L}/admin/`} class="drawer-link"><span data-i="nav.admin">🛡️ 管理后台</span></a>
        <a href={`${L}/subscribe/`} class="drawer-link"><span data-i="nav.subscribe">✨ 订阅更新</span></a>
      </nav>
    </aside>

    <main class="flex-1"><slot /></main>

    <!-- Footer -->
    <footer class="py-10 mt-16 border-t" style="border-color: var(--color-border)">
      <div class="container">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-sm" style="color: var(--color-text-muted)">
          <div class="flex items-center gap-2">
            <span class="text-lg">🤖</span>
            <span class="font-semibold" style="color: var(--color-text)">My AI Assets</span>
            <span data-i="footer.tagline">— Digital Garden</span>
          </div>
          <div class="flex items-center gap-6">
            <a href={`${L}/notes/`} style="color: var(--color-text-secondary)" data-i="nav.notes">笔记</a>
            <a href={`${L}/timeline/`} style="color: var(--color-text-secondary)" data-i="nav.timeline">时间线</a>
            <a href={`${L}/subscribe/`} style="color: var(--color-primary)" data-i="nav.subscribe">订阅</a>
          </div>
        </div>
        <p class="text-center mt-6" style="font-size: 0.75rem; color: var(--color-text-muted)">
          &copy; {new Date().getFullYear()} My AI Assets. Built with ❤️
        </p>
      </div>
    </footer>

    <back-to-top />

