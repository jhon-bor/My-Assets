      // Get language from URL path (e.g. /ja/notes -> ja)
      function getUrlLang() {
        var m = window.location.pathname.match(/^\/([a-z]{2})\//);
        if (m) return m[1];
        return null;
      }

      function syncUpdateUI() {
        // Prefer URL language over localStorage
        var urlLang = getUrlLang();
        var lang = urlLang || localStorage.getItem("lookfinde_lang") || "zh";
        var dict = T[lang] || T.zh;
        document.documentElement.setAttribute("data-lang", lang);

        // Translate all [data-i] elements
        document.querySelectorAll("[data-i]").forEach(function(el) {
          var k = el.getAttribute("data-i");
          if (k) {
            var v = (dict && dict[k]) || (T.zh[k]) || k;
            if (v && v !== k) {
              var count = el.getAttribute("data-count");
              el.textContent = count ? count + " " + v : v;
            }
          }
        });

        // Translate folder names
        document.querySelectorAll("[data-folder-name]").forEach(function(el) {
          var f = el.getAttribute("data-folder-name");
          if (f) {
            var v = (dict && dict["folder." + f]) || (T.zh["folder." + f]);
            if (v) el.textContent = "📁 " + v;
          }
        });

        // Translate note titles (data-title-{lang} → data-title-{currentLang})
        document.querySelectorAll(".note-title").forEach(function(el) {
          var t = el.getAttribute("data-title-" + lang) || el.getAttribute("data-title-zh") || "";
          if (t) el.textContent = t;
        });

        // Translate card titles/summaries
        document.querySelectorAll(".card-title").forEach(function(el) {
          var card = el.closest(".note-card");
          if (card) {
            var t = (card.getAttribute("data-titles") || "{}");
            try {
              var titles = JSON.parse(t);
              var v = titles[lang] || titles.zh || "";
              if (v) el.textContent = v;
            } catch(e) {}
          }
        });
        document.querySelectorAll(".card-summary").forEach(function(el) {
          var card = el.closest(".note-card");
          if (card) {
            var s = (card.getAttribute("data-summaries") || "{}");
            try {
              var summaries = JSON.parse(s);
              var v = summaries[lang] || summaries.zh || "";
              if (v) el.textContent = v;
            } catch(e) {}
          }
        });
      }

      // Apply immediately on page load
      syncUpdateUI();

      // Listen for langchange immediately (sync fallback before i18next loads)
      window.addEventListener("langchange", syncUpdateUI);

      // Full i18next-powered update after init
      init().then(function(i18n) {
        function updateUI() {
          // Prefer URL language over localStorage
          var urlLang = getUrlLang();
          var lang = urlLang || localStorage.getItem("lookfinde_lang") || "zh";
          var dict = T[lang] || T.zh;
          document.documentElement.setAttribute("data-lang", lang);

          // i18next handles data-i / data-i18n / data-i18n-placeholder / data-i18n-title
          document.querySelectorAll("[data-i]").forEach(function(el) {
            var k = el.getAttribute("data-i");
            if (k) {
              var t = i18n.t(k, { lng: lang });
              if (t && t !== k) el.textContent = t;
            }
          });
          document.querySelectorAll("[data-i18n]").forEach(function(el) {
            var k = el.getAttribute("data-i18n");
            if (k) {
              var t = i18n.t(k, { lng: lang });
              if (t && t !== k) el.textContent = t;
            }
          });
          document.querySelectorAll("[data-i18n-placeholder]").forEach(function(el) {
            var k = el.getAttribute("data-i18n-placeholder");
            if (k) {
              var t = i18n.t(k, { lng: lang });
              if (t && t !== k) (el).placeholder = t;
            }
          });
          document.querySelectorAll("[data-i18n-title]").forEach(function(el) {
            var k = el.getAttribute("data-i18n-title");
            if (k) {
              var t = i18n.t(k, { lng: lang });
              if (t && t !== k) el.setAttribute("title", t);
            }
          });
          document.querySelectorAll("[data-folder-name]").forEach(function(el) {
            var f = el.getAttribute("data-folder-name");
            if (f) {
              var v = i18n.t("folder." + f, { lng: lang });
              if (v && v !== "folder." + f) el.textContent = "📁 " + v;
            }
          });

          // Note titles via data-title-{lang}
          document.querySelectorAll(".note-title").forEach(function(el) {
            var t = el.getAttribute("data-title-" + lang) || el.getAttribute("data-title-zh") || "";
            if (t) el.textContent = t;
          });

          // Card titles/summaries via data-titles / data-summaries JSON
          document.querySelectorAll(".card-title").forEach(function(el) {
            var card = el.closest(".note-card");
            if (card) {
              try {
                var titles = JSON.parse(card.getAttribute("data-titles") || "{}");
                var v = titles[lang] || titles.zh || "";
                if (v) el.textContent = v;
              } catch(e) {}
            }
          });
          document.querySelectorAll(".card-summary").forEach(function(el) {
            var card = el.closest(".note-card");
            if (card) {
              try {
                var summaries = JSON.parse(card.getAttribute("data-summaries") || "{}");
                var v = summaries[lang] || summaries.zh || "";
                if (v) el.textContent = v;
              } catch(e) {}
            }
          });

          // Subscribe benefits
          document.querySelectorAll(".benefit-title").forEach(function(el, i) {
            var v = i18n.t("subscribe.benefit" + (i+1) + "Title", { lng: lang }) || "";
            if (v) el.textContent = v;
          });
          document.querySelectorAll(".benefit-desc").forEach(function(el, i) {
            var v = i18n.t("subscribe.benefit" + (i+1) + "Desc", { lng: lang }) || "";
            if (v) el.textContent = v;
          });

          // Timeline month labels
          document.querySelectorAll(".tl-month-label").forEach(function(el) {
            var year = el.getAttribute("data-year");
            var month = el.getAttribute("data-month");
            if (year && month) {
              var mNames = T[lang] && T[lang]["timeline.monthNames"] ? T[lang]["timeline.monthNames"] : T.zh["timeline.monthNames"];
              var monthName = mNames[parseInt(month)-1];
              var ym = lang === "en" ? "" : (T[lang] && T[lang]["timeline.yearMonth"] ? T[lang]["timeline.yearMonth"] : "年");
              el.textContent = year + ym + monthName;
            }
          });

          // Timeline weekday
          document.querySelectorAll(".tl-weekday").forEach(function(el) {
            var day = el.getAttribute("data-day");
            if (day !== null) {
              var weekdays = T[lang] && T[lang]["timeline.weekdays"] ? T[lang]["timeline.weekdays"] : T.zh["timeline.weekdays"];
              el.textContent = weekdays[parseInt(day)];
            }
          });
        }

        updateUI();
        // Replace sync listener with full i18next listener
        window.removeEventListener("langchange", syncUpdateUI);
        window.addEventListener("langchange", updateUI);
        window.__i18n_update = updateUI;
      });
    </script>

    <script>
      document.getElementById("mobile-menu-btn")?.addEventListener("click", () => {
        document.getElementById("mobile-drawer")?.classList.remove("translate-x-full");
        document.getElementById("mobile-drawer-overlay")?.classList.remove("hidden");
      });
    </script>
