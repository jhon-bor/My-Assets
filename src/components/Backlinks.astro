---
import type { Backlink } from "../utils/backlinks";

interface Props {
  backlinks: Backlink[];
  /** Language prefix for internal links (e.g. "zh", "en") */
  lang?: string;
}

const { backlinks, lang = "zh" } = Astro.props;
---

{backlinks.length > 0 && (
  <section class="backlinks-section">
    <h3 class="text-lg font-bold mb-4 flex items-center gap-2">
      🔗 反向链接
      <span class="backlinks-badge">{backlinks.length}</span>
    </h3>

    <ul class="space-y-2.5">
      {backlinks.map((bl) => (
        <li>
          <a href={`/${lang}/notes/${bl.slug}/`} class="backlink-item" style="text-decoration: none;">
            <span class="font-semibold block mb-1 text-sm" style="color: var(--color-text)">{bl.title}</span>
            <span class="block text-xs leading-relaxed" style="color: var(--color-text-secondary); font-size: 0.8rem;" set:html={bl.context} />
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .backlinks-section {
    margin-top: 3rem; padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .backlinks-badge {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 20px; height: 20px; padding: 0 6px;
    border-radius: var(--radius-full); font-size: 0.7rem; font-weight: 700;
    background: var(--color-bg-tertiary); color: var(--color-text-muted);
  }

  .backlink-item {
    display: block; padding: 0.85rem 1.1rem;
    border-radius: var(--radius-md); border: 1px solid transparent;
    background: var(--color-surface); box-shadow: var(--shadow-xs);
    transition: all 0.2s ease;
  }
  .backlink-item:hover {
    border-color: var(--color-primary-soft);
    box-shadow: var(--shadow-sm);
    transform: translateX(3px);
  }
</style>
