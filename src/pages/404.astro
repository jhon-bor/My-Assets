---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="页面未找到" noIndex={true}>
  <div class="container py-20 text-center">
    <p class="text-6xl mb-4">🔍</p>
    <h1 class="text-2xl font-bold mb-4">页面未找到</h1>
    <p style="color: var(--color-text-secondary); margin-bottom: 2rem">
      你访问的页面不存在，或笔记已被删除。
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-2 rounded-full font-semibold text-white px-8 py-3 shadow-lg transition-all active:scale-95"
      style="background: var(--color-primary); text-decoration: none; min-height: 48px"
    >
      ← 返回首页
    </a>
  </div>
</BaseLayout>
