---
export const prerender = false;
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import NoteCard from "../components/NoteCard.astro";
import FolderTree from "../components/FolderTree.astro";
import DbArticlesFeed from "../components/DbArticlesFeed";
import { extractFirstImage } from "../utils/images";
import { readDB } from "../lib/db";
import type { FolderItem } from "../components/FolderTree.astro";

const allNotes = await getCollection("notes");
const publishedNotes = allNotes
  .filter((n) => !n.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Get database articles (only approved ones)
const db = await readDB();
const dbArticles = db.articles.filter((a: any) => a.status === "approved");

// Combined totals
const totalNotes = publishedNotes.length + dbArticles.length;

const latestNotes = publishedNotes.slice(0, 5);
const featuredNotes = publishedNotes.filter((n) => n.data.featured);

const folderMap: Record<string, FolderItem[]> = {};
for (const note of publishedNotes) {
  const folder = note.data.folder || "未分类";
  if (!folderMap[folder]) folderMap[folder] = [];
  folderMap[folder].push({ slug: note.slug, title: note.data.title_zh });
}

// Add folders from database articles
for (const article of dbArticles) {
  const folder = article.folder || "数据库";
  if (!folderMap[folder]) folderMap[folder] = [];
  folderMap[folder].push({ slug: article.slug, title: article.title });
}

const totalFolders = Object.keys(folderMap).length;

// Collect images from recent notes for the gallery
const galleryImages = publishedNotes
  .map((n) => ({ src: extractFirstImage(n.body || ""), title: n.data.title, slug: n.slug }))
  .filter((i) => i.src)
  .slice(0, 6);
const galleryJson = JSON.stringify(galleryImages.map(i => i.src));
---

<BaseLayout
  title="首页"
  description="共享共建 · 数字花园 — 记录思考，分享知识。Obsidian 笔记公开站。"
>
  <!-- ── Hero: single dynamic background image ── -->
  <section class="hero-section">
    <div class="hero-slideshow" style={galleryImages.length > 0 ? `background-image: url('${galleryImages[0].src}')` : ""}></div>
    <div class="hero-overlay"></div>

    <!-- Hero text -->
    <div class="hero-content">
      <div class="container relative z-10">
        <div class="hero-badge">
          <span class="hero-dot"></span>
          {totalNotes} <span data-i="hero.badge">篇笔记 · 持续更新</span>
        </div>

        <h1 class="hero-title">
          <span class="hero-title-line"><span data-i="hero.title">共享共建</span> </span><span class="hero-title-sub" data-i="hero.titleSub">数字花园</span>
        </h1>

        <p class="hero-desc" data-i="hero.desc">一篇笔记，都是一颗种子。分享知识，共建花园，让思考在互联网上生长。</p>

        <div class="hero-actions">
          <a href="/notes/" class="hero-btn-primary">
            <span data-i="hero.explore">探索笔记</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a href="/publish/" class="hero-btn-ghost">
            <span data-i="hero.contribute">✍️ 参与共建</span>
          </a>
        </div>

       
       
        <div class="hero-stats">
          <div class="hero-stat">
            <span class="hero-stat-num">{totalNotes}</span>
            <span class="hero-stat-label" data-i="hero.statNotes">篇笔记</span>
          </div>
          <span class="hero-stat-divider"></span>
          <div class="hero-stat">
            <span class="hero-stat-num">{totalFolders}</span>
            <span class="hero-stat-label" data-i="hero.statFolders">个主题</span>
          </div>
          <span class="hero-stat-divider"></span>
          <div class="hero-stat">
            <span class="hero-stat-num">∞</span>
            <span class="hero-stat-label" data-i="hero.statInfinite">无限可能</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Main content ── -->
  <div class="container pb-16" style="padding-top: 40px;">
    <div class="flex flex-col lg:flex-row gap-8 lg:gap-12">
      <!-- Sidebar -->
      <aside class="hidden lg:block flex-shrink-0" style="width: 200px;">
        <div class="sticky top-20 space-y-8">
         
         
         
          <div class="sidebar-folder">
          <h4 class="sidebar-heading"><span data-i="sidebar.folders">📂 文件夹</span></h4>
          <FolderTree folders={folderMap} />
        </div>
          <div>
            <h4 class="sidebar-heading"><span data-i="sidebar.links">🔗 快捷</span></h4>
            <div class="space-y-1">
              <a href="/timeline/" class="sidebar-link"><span data-i="sidebar.timeline">⏰ 时间线</span></a>
              <a href="/subscribe/" class="sidebar-link"><span data-i="sidebar.subscribe">✨ 订阅更新</span></a>
              <a href="/publish/" class="sidebar-link"><span data-i="sidebar.publish">✍️ 发布文章</span></a>
            </div>
          </div>
        </div>
      </aside>

      <details class="lg:hidden mb-3">
        <summary class="sidebar-mobile-toggle" data-i="sidebar.folderNav">📂 文件夹导航</summary>
        <div class="mt-3 p-3 rounded-xl" style="background: var(--color-surface); border: 1px solid var(--color-border); box-shadow: var(--shadow-xs)">
          <FolderTree folders={folderMap} />
        </div>
      </details>

      <div class="flex-1 min-w-0">
        {featuredNotes.length > 0 && (
          <section class="mb-12">
            <div class="section-header">
              <h2 class="section-title"><span data-i="section.featured">🌟 精选</span></h2>
              <span class="section-badge" data-i="section.recommended">推荐</span>
            </div>
            <div class="space-y-3">
              {featuredNotes.map((note) => (
                <NoteCard
                  title_zh={note.data.title_zh}
                  title_en={note.data.title_en}
                  title_ja={note.data.title_ja}
                  title_fr={note.data.title_fr}
                  title_es={note.data.title_es}
                  title_pt={note.data.title_pt}
                  title_de={note.data.title_de}
                  title_it={note.data.title_it}
                  slug={note.slug}
                  date={note.data.date.toISOString()}
                  tags={note.data.tags}
                  summary_zh={note.data.summary_zh}
                  summary_en={note.data.summary_en}
                  summary_ja={note.data.summary_ja}
                  summary_fr={note.data.summary_fr}
                  summary_es={note.data.summary_es}
                  summary_pt={note.data.summary_pt}
                  summary_de={note.data.summary_de}
                  summary_it={note.data.summary_it}
                  folder={note.data.folder}
                  body_zh={note.body?.split(/<!-- EN -->/i)[0] || ""}
                  featured
                />
              ))}
            </div>
          </section>
        )}

        <section class="mb-12">
          <div class="section-header">
            <h2 class="section-title"><span data-i="section.latest">⏰ 最新</span></h2>
            <a href="/notes/" class="section-link"><span data-i="section.all">全部</span> →</a>
          </div>
          <div class="space-y-3">
            {latestNotes.map((note) => (
                <NoteCard
                  title_zh={note.data.title_zh}
                  title_en={note.data.title_en}
                  title_ja={note.data.title_ja}
                  title_fr={note.data.title_fr}
                  title_es={note.data.title_es}
                  title_pt={note.data.title_pt}
                  title_de={note.data.title_de}
                  title_it={note.data.title_it}
                  slug={note.slug}
                  date={note.data.date.toISOString()}
                  tags={note.data.tags}
                  summary_zh={note.data.summary_zh}
                  summary_en={note.data.summary_en}
                  summary_ja={note.data.summary_ja}
                  summary_fr={note.data.summary_fr}
                  summary_es={note.data.summary_es}
                  summary_pt={note.data.summary_pt}
                  summary_de={note.data.summary_de}
                  summary_it={note.data.summary_it}
                  folder={note.data.folder}
                  body_zh={note.body?.split(/<!-- EN -->/i)[0] || ""}
                />
              ))}          </div>
        </section>

        <section class="mb-12">
          <div class="section-header">
            <h2 class="section-title"><span data-i="section.community">🌐 社区投稿</span></h2>
            <span class="section-badge" style="background:#dcfce7;color:#16a34a" data-i="section.approved">已审核</span>
          </div>
          <div class="space-y-3">
            <DbArticlesFeed client:load />
          </div>
        </section>

        <div class="grid grid-cols-2 gap-3">
          <a href="/timeline/" class="quick-card group">
            <span class="text-3xl mb-3 block group-hover:scale-110 transition-transform duration-300">⏰</span>
            <span class="font-semibold block text-sm sm:text-base" style="color: var(--color-text)" data-i="quick.timeline">时间线</span>
            <span class="text-xs mt-1 block" style="color: var(--color-text-muted)" data-i="quick.timelineDesc">按时间浏览</span>
          </a>
          <a href="/subscribe/" class="quick-card group">
            <span class="text-3xl mb-3 block group-hover:scale-110 transition-transform duration-300">✨</span>
            <span class="font-semibold block text-sm sm:text-base" style="color: var(--color-text)" data-i="quick.subscribe">订阅更新</span>
            <span class="text-xs mt-1 block" style="color: var(--color-text-muted)" data-i="quick.subscribeDesc">第一时间获取</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* ── Hero section ── */
  .hero-section {
    position: relative;
    min-height: 180px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: var(--color-bg-secondary);
  }
  @media (min-width: 768px) { .hero-section { min-height: 220px; } }

  /* Dynamic slideshow background */
  .hero-slideshow {
    position: absolute; inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    animation: heroFade 18s infinite;
  }

  @keyframes heroFade {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom,
      rgba(0,0,0,0.3) 0%,
      rgba(0,0,0,0.55) 60%,
      rgba(0,0,0,0.8) 100%);
    pointer-events: none;
  }

  .hero-content {
    position: relative; z-index: 10;
    width: 100%;
    padding: 1.5rem 0;
  }
  @media (min-width: 768px) { .hero-content { padding: 2rem 0; } }

  .hero-badge {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.25rem 0.75rem; border-radius: var(--radius-full);
    font-size: 0.72rem; font-weight: 600;
    background: rgba(255,255,255,0.12);
    backdrop-filter: blur(10px);
    color: rgba(255,255,255,0.9);
    border: 1px solid rgba(255,255,255,0.15);
    margin-bottom: 0.75rem;
  }
  .hero-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: #10b981;
    box-shadow: 0 0 8px #10b981;
    animation: pulse-dot 2s infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .hero-title {
    margin-bottom: 1.25rem;
  }
  .hero-title-line {
    font-size: clamp(2.4rem, 8vw, 4.5rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.04em;
    color: #fff;
    text-shadow: 0 2px 20px rgba(0,0,0,0.3);
  }
  .hero-title-sub {
    font-size: clamp(1.8rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.05em;
    background: linear-gradient(135deg, #a5b4fc 0%, #c4b5fd 40%, #f9a8d4 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-desc {
    font-size: clamp(0.95rem, 2.5vw, 1.15rem);
    line-height: 1.8;
    color: rgba(255,255,255,0.75);
    max-width: 480px;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex; flex-wrap: wrap; gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .hero-btn-primary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.8rem 1.75rem; border-radius: var(--radius-full);
    font-size: 1rem; font-weight: 700; color: #fff; text-decoration: none;
    background: #fff; color: #1e1b4b;
    box-shadow: 0 4px 24px rgba(0,0,0,0.25);
    transition: all 0.3s ease; min-height: 48px;
  }
  .hero-btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 32px rgba(0,0,0,0.35);
  }
  .hero-btn-ghost {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.8rem 1.75rem; border-radius: var(--radius-full);
    font-size: 1rem; font-weight: 600; text-decoration: none;
    color: #fff; background: rgba(255,255,255,0.1);
    border: 1.5px solid rgba(255,255,255,0.25);
    backdrop-filter: blur(8px);
    transition: all 0.3s ease; min-height: 48px;
  }
  .hero-btn-ghost:hover {
    background: rgba(255,255,255,0.18);
    border-color: rgba(255,255,255,0.4);
  }

  /* Stats */
  .hero-stats {
    display: flex; align-items: center; gap: 1.5rem;
  }
  @media (min-width: 640px) { .hero-stats { gap: 2.5rem; } }
  .hero-stat { text-align: center; }
  .hero-stat-num {
    display: block;
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 900;
    color: #fff;
    line-height: 1;
  }
  .hero-stat-label {
    font-size: 0.75rem; font-weight: 500;
    color: rgba(255,255,255,0.6);
    margin-top: 0.3rem;
  }
  .hero-stat-divider {
    width: 1px; height: 28px;
    background: rgba(255,255,255,0.2);
  }

  /* ── Sections ── */
  .section-header {
    display: flex; align-items: center; gap: 0.75rem;
    margin-bottom: 1.25rem;
  }
  .section-title {
    font-size: 1.25rem; font-weight: 800;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }
  .section-link {
    font-size: 0.8rem; font-weight: 700;
    padding: 0.35rem 0.85rem; border-radius: var(--radius-full);
    color: var(--color-primary); background: var(--color-primary-light);
    text-decoration: none; transition: all 0.2s ease;
  }
  .section-link:hover { background: var(--color-primary-soft); }
  .section-badge {
    padding: 0.25rem 0.7rem; border-radius: var(--radius-full);
    font-size: 0.7rem; font-weight: 700;
    background: var(--color-accent-light); color: var(--color-accent);
  }

  /* ── Sidebar ── */
  .sidebar-folder {
    padding: 0.75rem;
    border-radius: var(--radius-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }
  .sidebar-heading {
    font-size: 0.85rem; font-weight: 800;
    letter-spacing: 0.02em; margin-bottom: 0.75rem;
    color: var(--color-text-muted);
  }
  .sidebar-link {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.6rem 0.75rem; border-radius: var(--radius-sm);
    font-size: 0.875rem; font-weight: 500; text-decoration: none;
    color: var(--color-text-secondary); transition: all 0.2s ease;
  }
  .sidebar-link:hover { color: var(--color-primary); background: var(--color-primary-light); }
  .sidebar-mobile-toggle {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.9rem 1rem; border-radius: var(--radius-lg);
    font-weight: 600; cursor: pointer;
    background: var(--color-surface); border: 1px solid var(--color-border);
    min-height: 48px; box-shadow: var(--shadow-xs);
  }

  /* Quick cards */
  .quick-card {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: 1.75rem 1.25rem; border-radius: var(--radius-xl);
    text-align: center; text-decoration: none;
    background: var(--color-surface); border: 1px solid var(--color-border);
    transition: all 0.3s ease; min-height: 130px;
    box-shadow: var(--shadow-xs);
  }
  .quick-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--color-primary);
    transform: translateY(-2px);
  }
</style>

{galleryImages.length > 1 && (
  <script define:vars={{ galleryJson }}>
    (function() {
      var images = galleryJson;
      var idx = 0;
      var el = document.querySelector('.hero-slideshow');
      if (!el || images.length < 2) return;
      setInterval(function() {
        idx = (idx + 1) % images.length;
        el.style.backgroundImage = 'url(' + images[idx] + ')';
      }, 6000);
    })();
  </script>
)}
