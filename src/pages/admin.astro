---
import BaseLayout from "../layouts/BaseLayout.astro";
import AdminDashboard from "../components/AdminDashboard";
---

<BaseLayout title="管理后台" description="文章审核与管理" noIndex>
  <div class="container py-8 sm:py-10">
    <h1 class="text-2xl sm:text-3xl font-extrabold mb-2">🛡️ 管理后台</h1>
    <p class="mb-8" style="color: var(--color-text-muted)">文章审核、发布管理</p>

    <AdminDashboard client:load />
  </div>
</BaseLayout>
